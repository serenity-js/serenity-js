{
  "extends": "../../tsconfig.options.json",

  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./lib",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "types": [
      "node",
      "mocha"
    ]
  },

  "include": [
    "src/**/*.ts",
    "spec/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
