{
  "name": "@serenity-js/web",
  "version": "3.42.0",
  "description": "Serenity/JS Screenplay Pattern library offering a flexible, web driver-agnostic approach for interacting with web-based user interfaces and components, suitable for various testing contexts",
  "author": {
    "name": "Jan Molak",
    "email": "jan.molak@smartcodeltd.co.uk",
    "url": "https://janmolak.com"
  },
  "funding": {
    "url": "https://github.com/sponsors/serenity-js"
  },
  "homepage": "https://serenity-js.org",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "lib/index.js",
  "module": "./esm/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./scripts": {
      "import": {
        "types": "./esm/scripts/index.d.ts",
        "default": "./esm/scripts/index.js"
      },
      "require": {
        "types": "./lib/scripts/index.d.ts",
        "default": "./lib/scripts/index.js"
      }
    },
    "./lib/scripts": {
      "import": {
        "types": "./esm/scripts/index.d.ts",
        "default": "./esm/scripts/index.js"
      },
      "require": {
        "types": "./lib/scripts/index.d.ts",
        "default": "./lib/scripts/index.js"
      }
    },
    "./lib/*": "./lib/*",
    "./esm/*": "./esm/*",
    "./package.json": "./package.json"
  },
  "keywords": [
    "automation",
    "browser",
    "component",
    "e2e",
    "end-to-end",
    "integration",
    "serenity",
    "serenity-js",
    "screenplay",
    "screenplay-pattern",
    "tdd",
    "bdd",
    "test",
    "testing",
    "web"
  ],
  "scripts": {
    "clean": "rimraf target",
    "test": "c8 npm run test:no-coverage",
    "test:no-coverage": "mocha --config .mocharc.yml --spec='spec/**/*.spec.*'",
    "compile:clean": "rimraf lib esm",
    "compile:esm": "tsc --project tsconfig-esm.build.json",
    "compile:cjs-package": "node -e \"require('fs').mkdirSync('lib', { recursive: true }); require('fs').writeFileSync('lib/package.json', JSON.stringify({ type: 'commonjs' }))\"",
    "compile:cjs": "tsc --project tsconfig-cjs.build.json",
    "compile": "npm run compile:clean && npm run compile:esm && npm run compile:cjs-package && npm run compile:cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/serenity-js/serenity-js.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/serenity-js/serenity-js/issues"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "dependencies": {
    "@serenity-js/assertions": "workspace:*",
    "@serenity-js/core": "workspace:*",
    "tiny-types": "2.0.5"
  },
  "devDependencies": {
    "@integration/testing-tools": "workspace:*",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "c8": "11.0.0",
    "mocha": "11.7.5",
    "mocha-multi": "1.1.7",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
